{
  "manifest_version": 3,
  "name": "ContextPilot",
  "version": "3.0.0",
  "description": "Save tokens. Stay in conversations. Live usage bars, blast-radius graph, quality scoring, and /cp commands for claude.ai.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://api.anthropic.com/*",
    "https://console.anthropic.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["vendor/gpt-tokenizer.js", "vendor/d3.min.js", "dist/content_script.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://console.anthropic.com/*"],
      "js": ["dist/content_script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/*", "icons/*", "dist/*"],
      "matches": ["https://claude.ai/*", "https://console.anthropic.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ContextPilot"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
